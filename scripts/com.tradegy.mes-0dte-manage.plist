<?xml version="1.0" encoding="UTF-8"?>
<!--
  Companion plist to com.tradegy.mes-0dte.plist (the entry job).
  Schedules the MANAGE script every 15 min from 10:45 to 15:45 ET
  (Mon-Thu only — same expiry-day filter as the entry job).

  Each run is cheap and idempotent:
    - No-op if no entry record exists for today
    - No-op if the position is already closed
    - Otherwise: fetch live quotes, compute MTM, trigger PT 50% if
      threshold reached

  Install / unload alongside the entry plist:
    cp scripts/com.tradegy.mes-0dte-manage.plist \
       ~/Library/LaunchAgents/com.tradegy.mes-0dte-manage.plist
    launchctl load ~/Library/LaunchAgents/com.tradegy.mes-0dte-manage.plist
-->
