[Unit]
Description=Tradegy MES 0DTE paper management sweep
Documentation=file:/opt/tradegy/trading_platform_docs/17_gcp_mes_0dte_deployment.md
After=network-online.target docker.service tradegy-ib-gateway.service
Wants=network-online.target docker.service tradegy-ib-gateway.service
Requires=tradegy-ib-gateway.service

[Service]
Type=oneshot
EnvironmentFile=/etc/tradegy/mes-0dte.env
ExecStartPre=-/usr/bin/docker rm -f tradegy-mes-manage
ExecStart=/usr/bin/docker run --rm --name tradegy-mes-manage --network host --env-file /etc/tradegy/mes-0dte.env --volume /var/lib/tradegy:/var/lib/tradegy ${TRADEGY_IMAGE} --manage
TimeoutStartSec=180
