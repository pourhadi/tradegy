# Copy to /etc/tradegy/mes-0dte.env on the GCE VM and fill values from
# Secret Manager. Do not commit the real file.

TRADEGY_IMAGE=us-central1-docker.pkg.dev/PROJECT_ID/tradegy/tradegy-mes-0dte:latest

# Persistent state mounted by the systemd Docker units.
TRADEGY_DATA_DIR=/var/lib/tradegy/data
TRADEGY_LIVE_OPTIONS_DIR=/var/lib/tradegy/data/live_options
TRADEGY_MARKET_TZ=America/New_York
TZ=America/New_York

# IB Gateway paper API. With host-network Docker and Gateway on the same
# VM, 127.0.0.1 is the correct target.
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=23
IBKR_PAPER_ACCOUNT=DU7535411
