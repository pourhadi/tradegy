# Copy to /etc/tradegy/ib-gateway.env on the GCE VM. This file contains
# non-secret runtime config plus Secret Manager secret names. The actual IBKR
# password and VNC password are materialized into /run/tradegy at service start.

IB_GATEWAY_IMAGE=ghcr.io/gnzsnz/ib-gateway:stable

# GCP Secret Manager names. Populate these secrets out-of-band with
# `gcloud secrets versions add`; do not put secret values in this file.
GCP_SECRET_IBKR_USERNAME=tradegy-ibkr-username
GCP_SECRET_IBKR_PASSWORD=tradegy-ibkr-password
GCP_SECRET_IBKR_VNC_PASSWORD=tradegy-ib-gateway-vnc-password

# IB Gateway / IBC configuration.
TRADING_MODE=paper
READ_ONLY_API=no
TWS_ACCEPT_INCOMING=accept
TWS_SETTINGS_PATH=/home/ibgateway/tws_settings
TIME_ZONE=America/New_York
TZ=America/New_York

# IBC restart behavior. AUTO_RESTART_TIME should be outside market hours.
AUTO_RESTART_TIME=11:45 PM
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TWOFA_EXIT_INTERVAL=120
EXISTING_SESSION_DETECTED_ACTION=primary
BYPASS_WARNING=yes
ALLOW_BLIND_TRADING=no
SAVE_TWS_SETTINGS=11:40 PM

# Optional: pin a specific 2FA target if your account has multiple devices.
TWOFA_DEVICE=
